# =============================================================================
# Filaha — Root .gitignore
# =============================================================================

# --- Dependencies ---
node_modules/
package-lock.json

# --- Environment / Secrets ---
.env
.env.local
.env.*.local

# --- Internal / Dev-only ---
Rules/
Project_Description/
.cursorrules

# --- Frontend (not for public repo) ---
frontend/

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editors / IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Coverage / Reports ---
coverage/
.nyc_output/

# --- Build artifacts ---
dist/
build/
