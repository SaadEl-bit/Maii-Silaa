# Auto detect text files and normalize to LF in repo
* text=auto

# Explicit LF for code files (cross-platform consistency)
*.js     text eol=lf
*.json   text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.md     text eol=lf
*.sql    text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf

# Binary files (never touch these)
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.svg    binary
*.ttf    binary
*.woff   binary
*.woff2  binary
*.eot    binary
*.zip    binary

# Node
node_modules/ export-ignore
